# Application Settings
APP_NAME=Swatantra
DEBUG=False
ENVIRONMENT=production

# Database Configuration
# Options: "postgresql" for cloud, "sqlite" for offline
DB_TYPE=sqlite

# PostgreSQL Settings (for cloud deployment)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=swatantra

# SQLite Settings (for local/offline development)
SQLITE_DB_PATH=./data/swatantra.db

# API Configuration
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost

# LLM Configuration - Online Mode (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-3.5-turbo
TEMPERATURE=0.7
MAX_TOKENS=2048

# Offline LLM Configuration
USE_OFFLINE_LLM=False
OLLAMA_BASE_URL=http://localhost:11434
OFFLINE_LLM_MODEL=mistral

# Agent Settings
MAX_AGENT_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=300

# AWS Configuration (for cloud deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
